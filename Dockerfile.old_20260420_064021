# ============================================================================
#  Wan2.2 Rapid-Mega I2V — RunPod Serverless Worker
#  RTX 4090 (Ada Lovelace sm_89) 最適化版 v4
# ----------------------------------------------------------------------------
#  設計方針（2026-04-19 v4）:
#   - ベースイメージ既定の PyTorch（cu124 stable）を維持
#   - 5090向け cu128 nightly を廃止（4090には不要、不安定要因）
#   - sage-attention を有効化（4090で動作確認済みのwheel）
#   - fp16 accumulation 有効（Ada世代の専用最適化）
#   - comfy_kitchen backend cuda / triton を有効化（disabled フラグを外す）
#   - async weight offloading + pinned memory で VRAM 24GB を最大活用
#
#  配信: RunPod GitHub Integration で直接ビルド（ghcr.io 不要）
# ============================================================================

FROM runpod/worker-comfyui:5.8.5-base

# ---------------------------------------------------------------------------
# 1) sage-attention インストール（4090で30%速くなる）
# ---------------------------------------------------------------------------
# PyTorch 2.4系対応のsageattention 1.0.6を使用
# （kijai氏の事前ビルドwheelはPyTorch/CUDA組み合わせでDLLエラーが出るため
#  pip版を使用。cuda backend disabled問題はこれで解決）
RUN pip install --no-cache-dir sageattention==1.0.6 || \
    pip install --no-cache-dir sageattention

# ---------------------------------------------------------------------------
# 2) triton 最新版（comfy_kitchen triton バックエンド有効化用）
# ---------------------------------------------------------------------------
RUN pip install --no-cache-dir -U triton

# ---------------------------------------------------------------------------
# 3) ComfyUI 本体を最新版に更新（WanVaceToVideo ネイティブ対応）
# ---------------------------------------------------------------------------
RUN cd /comfyui && \
    git fetch --all --tags && \
    git checkout master && \
    git pull origin master && \
    pip install --no-cache-dir -r requirements.txt

# ---------------------------------------------------------------------------
# 4) カスタムノード（VideoHelperSuite + video-output-bridge）
# ---------------------------------------------------------------------------
RUN comfy-node-install comfyui-videohelpersuite video-output-bridge

# ---------------------------------------------------------------------------
# 5) extra_model_paths.yaml（Network Volume モデル認識）
# ---------------------------------------------------------------------------
COPY extra_model_paths.yaml /comfyui/extra_model_paths.yaml

# ---------------------------------------------------------------------------
# 6) ComfyUI 起動オプション（4090 最適化）
# ---------------------------------------------------------------------------
#   --use-sage-attention: attention を30%速い sage実装に切替
#   --fast: fp16 accumulation 有効化（Adaの専用最適化）
#   --highvram: 24GB VRAMを前提にVRAM優先モード（遅延ロード無効）
ENV COMFY_ARGS="--use-sage-attention --fast --highvram"

# ---------------------------------------------------------------------------
# 7) comfy_kitchen バックエンドの有効化（環境変数で disabled フラグを外す）
# ---------------------------------------------------------------------------
# ログで「disabled: True」だった cuda / triton バックエンドを強制有効化
ENV COMFY_KITCHEN_FORCE_ENABLE=1

# ---------------------------------------------------------------------------
# 8) クリーンアップ
# ---------------------------------------------------------------------------
RUN rm -f /comfyui/test_input.json 2>/dev/null || true && \
    rm -rf /root/.cache/pip

# ---------------------------------------------------------------------------
# 9) ビルド時ヘルスチェック
# ---------------------------------------------------------------------------
RUN python -c "import torch; \
    print(f'PyTorch: {torch.__version__}'); \
    print(f'CUDA: {torch.version.cuda}'); \
    try: \
        import sageattention; \
        print(f'sageattention: OK'); \
    except ImportError as e: \
        print(f'sageattention: NG - {e}')" || true
